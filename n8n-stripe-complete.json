    {
      "parameters": {
        "jsCode": "// Extrahuje event ID a základní data z libovolného Stripe webhook payloadu\nconst body = $input.first().json.body || {};\n\nconst eventId = body.id || '';\nconst eventType = body.type || 'unknown';\n\nlet stripeId = eventId;\nlet amount = 0;\nlet currency = '';\nlet customerName = '-';\nlet customerEmail = '-';\nlet status = '-';\nlet metadata = {};\n\nif (body.data && body.data.object) {\n  const obj = body.data.object;\n  stripeId = obj.id || eventId;\n  \n  if (eventType === 'checkout.session.completed' || eventType === 'checkout.session.async_payment_succeeded') {\n    amount = obj.amount_total || 0;\n    currency = obj.currency || '';\n    customerName = obj.customer_details?.name || '-';\n    customerEmail = obj.customer_details?.email || '-';\n    status = obj.payment_status || '-';\n    metadata = obj.metadata || {};\n  } else if (eventType.startsWith('payment_intent.')) {\n    amount = obj.amount || 0;\n    currency = obj.currency || '';\n    customerEmail = obj.receipt_email || '-';\n    status = obj.status || '-';\n    metadata = obj.metadata || {};\n  }\n}\n\nreturn [{\n  json: {\n    eventId: eventId || stripeId,\n    eventType,\n    stripeId,\n    amount,\n    currency,\n    customerName,\n    customerEmail,\n    status,\n    metadata,\n    rawBody: body\n  }\n}];"
      },
      "id": "code-001",
      "name": "Extract Event Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        460,
        360
      ]
    },
