    {
      "parameters": {
        "jsCode": "// Sběr výsledků ze všech notifikačních nodů pro logování\nconst items = $input.all();\nconst results = items.map((item, idx) => {\n  const hasError = item.json && item.json.error;\n  return {\n    step: idx,\n    node: item.json && item.json.error ? 'FAILED' : 'OK',\n    detail: hasError ? (item.json.error.message || 'Unknown error') : 'Success',\n    timestamp: new Date().toISOString()\n  };\n});\n\nconst hasError = results.some(r => r.node === 'FAILED');\n\nreturn [{\n  json: {\n    executionSummary: results,\n    hasError,\n    loggedAt: new Date().toISOString()\n  }\n}];"
      },
