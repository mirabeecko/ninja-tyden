    {
      "parameters": {
        "jsCode": "const eventId = $input.first().json.eventId;\nconst rows = $input.all()[0]?.json?.data || $input.all()[0]?.json || [];\nconst rowArray = Array.isArray(rows) ? rows : [];\n\n// Hledáme eventId ve sloupci H (Stripe ID)\nconst found = rowArray.some(row => {\n  const rowData = row.json || row;\n  return rowData['Stripe ID'] === eventId || rowData.stripeId === eventId;\n});\n\nreturn [{ json: { isDuplicate: found, eventId } }];"
      },
